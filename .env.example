# Neon Postgres (async URL for SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# API
API_HOST=0.0.0.0
API_PORT=8000

# Worker
REQUIRE_PERSON_NEAR_PLATE=true
# UUID of the cameras row to use (from seed or DB)
WORKER_CAMERA_ID=
# Empty = use camera.rtsp_url from DB for live RTSP. Or set a file path, directory (BATCH_101…), or rtsp://… URL
VIDEO_SOURCE=
# Optional: stop each clip after N frames (applies per clip in batch directory mode)
WORKER_MAX_FRAMES=
TARGET_FPS=5
SERVE_DWELL_SECONDS=2.0
# Debug preview: off | imshow (OpenCV window with zones + detections; local dev only)
WORKER_PREVIEW=off
# Reserved for future browser MJPEG preview
WORKER_PREVIEW_PORT=8080

# ML (optional paths)
YOLO_WEIGHTS=yolov8n.pt
# ROI: crop to serving zone bounds (+ padding) for detection when zones exist; helps small objects
YOLO_ROI_CROP=true
YOLO_ROI_PADDING_FRAC=0.15
CLASSIFIER_CHECKPOINT=
